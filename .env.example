# Copy this file to .env.local and add your Cesium Ion access token.
# Get a token (free) at https://ion.cesium.com/tokens
# Without a token the app falls back to token-free OpenStreetMap imagery
# and a plain ellipsoid (no terrain).
VITE_CESIUM_ION_TOKEN=

# Optional: Google Maps Platform API key for Photorealistic 3D Tiles.
# (Alternatively, enable asset 2275207 in your Cesium ion account.)
VITE_GOOGLE_MAPS_API_KEY=
